DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/checkstack
CHECK_INTERVAL_SECONDS=15
CHECK_TIMEOUT_SECONDS=10
CHECK_RETRY_ATTEMPTS=3
INCIDENT_OPEN_AFTER_FAILURES=3
INCIDENT_CLOSE_AFTER_SUCCESSES=2
INCIDENT_DEBOUNCE_SECONDS=120
API_HOST=0.0.0.0
API_PORT=8000

# Links in email/slack; point at your public web UI
PUBLIC_BASE_URL=https://status.example.com

# Optional default Slack (per-alert webhooks in DB take precedence)
SLACK_DEFAULT_WEBHOOK_URL=

# SMTP (email alert channels)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=checkstack@localhost
SMTP_USE_TLS=true
